# On24 API Configuration
# Get these from your On24 API Dashboard
ON24_CLIENT_ID=your_client_id
ON24_TOKEN_KEY=your_token_key
ON24_TOKEN_SECRET=your_token_secret

# API Base URL (use EU endpoint if your account is EU-based)
ON24_API_BASE_URL=https://api.on24.com/v2
# ON24_API_BASE_URL=https://api.eu.on24.com/v2

# Cache Configuration (hours)
CACHE_TTL_HOURS=24
